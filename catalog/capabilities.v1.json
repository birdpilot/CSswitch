      "id": "transport.connect.non-anthropic-direct-tunnel",
      "scope": "transport",
      "match": {
        "method": "CONNECT",
        "host": "non_anthropic"
      },
      "status": "limited",
      "action": "document",
      "reason": "Non-Anthropic CONNECT opens a direct TCP tunnel. One 10-second dial budget starts before synchronous DNS and is shared across resolved addresses; std DNS itself cannot be interrupted by that budget. External MCP access can still fail where direct egress is blocked.",
      "evidence": [
        "desktop/gateway/src/server.rs",
        "desktop/gateway/src/connect.rs",
        "https://github.com/SuperJJ007/CSSwitch/issues/11"
      ],
      "tests": [

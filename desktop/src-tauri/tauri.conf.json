{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSSwitch",
  "version": "0.4.4",
  "identifier": "com.csswitch.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CSSwitch",
        "width": 420,
        "height": 700,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../scripts/doctor.sh": "scripts/doctor.sh",
      "../../scripts/launch-virtual-sandbox.sh": "scripts/launch-virtual-sandbox.sh",
      "../../scripts/stop-science-sandbox.sh": "scripts/stop-science-sandbox.sh",
      "../../scripts/verify-proxy.sh": "scripts/verify-proxy.sh"
    },
    "externalBin": [
      "binaries/csswitch-gateway"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
